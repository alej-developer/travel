DATABASE_URL=postgresql+asyncpg://travel:travel@localhost:5432/travel_db
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
DEBUG=true

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
REDIS_URL=redis://localhost:6379/0

# --- Proxy rotation (residencial) ---
# Format: socks5://user:pass@host:port  or  http://user:pass@host:port
PROXY_LIST=socks5://user:pass@proxy1.example.com:1080,socks5://user:pass@proxy2.example.com:1080

# --- Circuit Breaker ---
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT_SECONDS=900

# --- Scraper concurrency ---
SCRAPER_MAX_CONCURRENT_PAGES=5

# --- Security: CORS (no wildcards!) ---
# Comma-separated exact origins. Example:
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# --- Security: Rate Limiting ---
RATE_LIMIT_GLOBAL_REQUESTS=50
RATE_LIMIT_SEARCH_REQUESTS=5
RATE_LIMIT_ENABLED=true

# --- Security: OWASP Headers ---
# HSTS max-age in seconds (31536000 = 1 year)
SECURITY_HSTS_MAX_AGE=31536000
# Override CSP only if you need custom directives:
# SECURITY_CSP=default-src 'none'; script-src 'self'; ...
