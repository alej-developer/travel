DATABASE_URL=postgresql+asyncpg://travel:travel@localhost:5432/travel_db
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
DEBUG=true

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
REDIS_URL=redis://localhost:6379/0

# --- Proxy rotation (residencial) ---
# Format: socks5://user:pass@host:port  or  http://user:pass@host:port
PROXY_LIST=socks5://user:pass@proxy1.example.com:1080,socks5://user:pass@proxy2.example.com:1080

# --- Circuit Breaker ---
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT_SECONDS=900

# --- Scraper concurrency ---
SCRAPER_MAX_CONCURRENT_PAGES=5
